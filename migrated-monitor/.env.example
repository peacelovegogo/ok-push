# Binance Web3 Meme Rush 已迁移代币监控
# 复制为 .env 后填写你自己的 Telegram 配置

TELEGRAM_BOT_TOKEN=your_migrated_bot_token
TELEGRAM_CHAT_ID=your_migrated_chat_id

# 可选：当 Binance 已迁移官方接口对脚本返回空列表，但你在浏览器页面里能看到数据时，
# 可把浏览器请求头里的完整 Cookie 字符串填到这里，复用已通过 WAF 挑战的网页会话。
# MIGRATED_COOKIE_HEADER=aws-waf-token=...; other_cookie=...

# 可选：自定义请求 User-Agent；留空时使用默认值。
# MIGRATED_API_USER_AGENT=Mozilla/5.0 ...
